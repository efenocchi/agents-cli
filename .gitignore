# Dependencies
node_modules/
package-lock.json

# Build output
dist/
*.tsbuildinfo

# Compiled keychain helper + provisioning profile (rebuild via apps/cli/scripts/build-keychain-helper.sh)
/apps/cli/bin/

# Sha pin for the signed standalone CLI binary - a per-release build artifact,
# regenerated by apps/cli/scripts/sign-cli-binary.sh alongside the binary it
# pins. Committing it would go stale against a re-signed binary on every
# publish re-run (unlike the rarely-rebuilt keychain helper's committed pin).
/apps/cli/scripts/agents-cli-bin.sha256

# Caches
.npm-cache/

# Logs
*.log

# Environment / secrets
.env
.env.*

# OS
.DS_Store
Thumbs.db

# Editors
.vscode/
.idea/
*.swp
*.swo

# Test coverage
coverage/

# Generated test reports (session-tracker scenario recorder, run-report aggregator)
**/tests/reports/

# Internal plans (not shipped)
.agents/plans/
.agents/worktrees/
.agents/scratch/
.agents/artifacts/
.plans/

# Scrub script lists personal data strings — must not be committed to public repo
scripts/scrub-history.sh

# Other
.refs/
.crabbox/
.rush/

# Agents (recurisve)
**/.claude
**/.codex
**/.gemini
**/.tmp
**/.tmp-bun

# Plugin executables — built/installed artifacts, never committed
**/plugins/*/bin/

# Cloudflare Worker local state
**/.wrangler/

# Local scratch / abandoned scaffold (lives in agent-cli-web, not here)
/website/
.e2e-pack-*
