{
  "name": "swarm-app",
  "version": "0.0.1",
  "private": true,
  "description": "Standalone Electron app for the Factory work stream",
  "main": "dist/main.js",
  "scripts": {
    "build:ui": "cd ../ui && bunx vite build --config vite.standalone.config.ts",
    "build:host": "bun build ./main.ts --target=node --format=cjs --outfile=./dist/main.js --external electron && bun build ./preload.ts --target=node --format=cjs --outfile=./dist/preload.js --external electron",
    "build": "bun run build:ui && bun run build:host",
    "typecheck": "bunx tsc -p ./tsconfig.json --noEmit",
    "dist": "electron-builder",
    "start": "electron ./dist/main.js"
  },
  "build": {
    "appId": "com.swarmify.factory",
    "productName": "Factory",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [
      { "from": "../out/app-ui", "to": "app-ui" },
      { "from": "../assets", "to": "assets" }
    ],
    "mac": {
      "target": ["dmg", "zip"],
      "icon": "../assets/agents.png",
      "category": "public.app-category.developer-tools",
      "notarize": false
    },
    "linux": {
      "target": ["AppImage"],
      "icon": "../assets/agents.png",
      "category": "Development"
    },
    "win": {
      "target": ["nsis"],
      "icon": "../assets/agents.png"
    }
  },
  "devDependencies": {
    "electron": "^34.2.0",
    "electron-builder": "^25.1.8"
  }
}
